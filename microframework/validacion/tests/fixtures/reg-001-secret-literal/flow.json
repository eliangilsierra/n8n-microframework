{
  "name": "fixture-reg-001",
  "nodes": [
    {
      "id": "n1",
      "name": "Webhook In",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": { "path": "in", "httpMethod": "POST" }
    },
    {
      "id": "n2",
      "name": "Call API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [200, 0],
      "parameters": {
        "url": "https://api.example.com/x",
        "options": { "retry": { "enabled": true, "maxRetries": 3 } },
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "sk-1234567890abcdef1234567890" }
          ]
        }
      }
    },
    {
      "id": "n3",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [400, 0],
      "parameters": { "responseCode": 200 }
    }
  ],
  "connections": {
    "Webhook In": { "main": [[{ "node": "Call API", "type": "main", "index": 0 }]] },
    "Call API": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  },
  "settings": { "errorWorkflow": "" }
}

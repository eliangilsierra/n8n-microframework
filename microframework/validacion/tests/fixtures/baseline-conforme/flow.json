{
  "name": "fixture-conforme",
  "nodes": [
    {
      "id": "n1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "parameters": {}
    },
    {
      "id": "n2",
      "name": "Validar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0],
      "parameters": {
        "jsCode": "const run_id = crypto.randomUUID(); console.log(JSON.stringify({ run_id, etapa: 'E1', status: 'ok' })); return [{ json: { run_id } }];"
      }
    },
    {
      "id": "n3",
      "name": "Insertar",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [400, 0],
      "parameters": {
        "operation": "insert",
        "query": "INSERT INTO t (id, v) VALUES ($1, $2) ON CONFLICT (id) DO NOTHING"
      }
    },
    {
      "id": "n4",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [600, 0],
      "parameters": { "responseCode": 200 }
    },
    {
      "id": "n5",
      "name": "Respond Err",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [600, 100],
      "parameters": { "responseCode": 422 }
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Validar", "type": "main", "index": 0 }]] },
    "Validar": { "main": [[{ "node": "Insertar", "type": "main", "index": 0 }]] },
    "Insertar": { "main": [[{ "node": "Respond OK", "type": "main", "index": 0 }]] }
  },
  "settings": { "errorWorkflow": "wf-error-handler-01" }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "iot-e2-output.schema.json",
  "title": "IoT — salida de E2 (análisis de dominio)",
  "type": "object",
  "required": ["run_id", "analisis", "e2_start", "e2_end"],
  "properties": {
    "run_id": { "type": "string" },
    "analisis": {
      "type": "object",
      "required": ["nivel", "requiereNotificacion", "regla_aplicada"],
      "properties": {
        "nivel": {
          "type": "string",
          "enum": ["normal", "advertencia", "critico"]
        },
        "requiereNotificacion": { "type": "boolean" },
        "regla_aplicada": { "type": "string", "pattern": "^R[0-9]{3}$" },
        "anomalias": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["campo", "valor", "umbral", "tipo"],
            "properties": {
              "campo": { "type": "string" },
              "valor": { "type": "number" },
              "umbral": { "type": "number" },
              "tipo": { "type": "string", "enum": ["advertencia", "critico"] }
            }
          }
        }
      }
    },
    "lectura": { "type": "object" },
    "e2_start": { "type": "string", "format": "date-time" },
    "e2_end": { "type": "string", "format": "date-time" }
  }
}

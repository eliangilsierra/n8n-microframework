{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "iot-e3-output.schema.json",
  "title": "IoT — salida de E3 (persistencia en Postgres)",
  "type": "object",
  "required": ["run_id", "persistencia", "idempotency_key", "e3_start", "e3_end"],
  "properties": {
    "run_id": { "type": "string" },
    "idempotency_key": {
      "type": "string",
      "description": "Formato: {sensor_id}-{timestamp ISO}"
    },
    "persistencia": {
      "type": "object",
      "required": ["status", "registro_id"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["creado", "duplicado_omitido", "fallido"]
        },
        "registro_id": { "type": ["string", "integer", "null"] }
      }
    },
    "reintentos": { "type": "integer", "minimum": 0 },
    "analisis": { "type": "object" },
    "e3_start": { "type": "string", "format": "date-time" },
    "e3_end": { "type": "string", "format": "date-time" }
  }
}

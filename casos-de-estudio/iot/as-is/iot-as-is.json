      "id": "b1c2d3e4-0012-0012-0012-000000000012",
      "name": "Enviar Notificacion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2440, 320]
    },
    {
      "parameters": {
        "jsCode": "// Antipatron REG-006: log sin estructura, sin run_id, sin etapa\n// Antipatron REG-002: run_id ausente en todo el flujo\nconst d = $('Determinar Nivel Final').item.json;\nconsole.log(JSON.stringify({\n  sensor_id: d.sensor_id,\n  nivel:     d.nivel,\n  ts:        d.timestamp\n}));\nreturn [{ json: d }];"
      },

          },
          "conditions": [
            {
              "id": "cond-notif",
              "leftValue": "={{ $('Determinar Nivel Final').item.json.requiere_notificacion }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],

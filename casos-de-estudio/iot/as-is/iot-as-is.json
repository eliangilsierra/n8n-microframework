            {
              "name": "Content-Type",
              "value": "text/plain; charset=utf-8"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "text/plain",
        "body": "={{ 'lecturas,sensor=' + $json.sensor_id + ' temperatura=' + $json.temperatura + ',humedad=' + $json.humedad + ',co2=' + ($json.co2_raw || 0) + ' ' + Date.now() }}",
        "options": {}
      },
      "id": "b1c2d3e4-0009-0009-0009-000000000009",
      "name": "Guardar en InfluxDB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 440]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO lecturas_sensor (sensor_id, temperatura, humedad, co2, nivel, location, ts)\nVALUES ('{{ $('Determinar Nivel Final').item.json.sensor_id }}',\n        {{ $('Determinar Nivel Final').item.json.temperatura }},\n        {{ $('Determinar Nivel Final').item.json.humedad }},\n        {{ $('Determinar Nivel Final').item.json.co2_raw || 0 }},\n        '{{ $('Determinar Nivel Final').item.json.nivel }}',\n        '{{ $('Determinar Nivel Final').item.json.location }}',\n        NOW());",
        "options": {}
      },
      "id": "b1c2d3e4-0010-0010-0010-000000000010",
      "name": "Persistir en PostgreSQL",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2000, 440]
    },
    {
      "parameters": {
        "conditions": {
          "options": {

{
  "name": "BOT-TO-BE - Chatbot de soporte (micro-framework aplicado)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "bot-support-to-be",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-entrada",
      "name": "Webhook - Entrada",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "bot-to-be-001"
    },
    {
      "parameters": {
        "jsCode": "// ETAPA 1 - Validacion de entrada\n// ADR-005: token validado contra BOT_API_TOKEN (sin hardcodear — REG-001)\nconst run_id = `RUN-BOT-${new Date().toISOString().replace(/[-:.TZ]/g,'').slice(0,15)}-${Math.random().toString(36).substr(2,5).toUpperCase()}`;\nconst start_ts = new Date().toISOString();\nconst body = $input.item.json.body || {};\n\nconst errores = [];\nlet unauthorized = false;\nconst tokenPresente = !!body.token;\n\nif (!tokenPresente) errores.push('Campo requerido: token');\nif (!body.message || typeof body.message !== 'string') errores.push('Campo requerido: message (string)');\nif (!body.user_id || typeof body.user_id !== 'string') errores.push('Campo requerido: user_id (string)');\nif (body.message && body.message.length > 1000) errores.push('message excede 1000 caracteres');\n\nif (tokenPresente) {\n  try {\n    const expectedToken = $env.BOT_API_TOKEN;\n    if (expectedToken && body.token !== expectedToken) {\n      errores.push('Token de autenticacion invalido');\n      unauthorized = true;\n    }\n  } catch(e) { /* $env no disponible — solo se valida presencia */ }\n}\n\nconst valido = errores.length === 0;\n\nconsole.log(JSON.stringify({\n  run_id,\n  etapa: 'E1_validacion',\n  status: valido ? 'ok' : 'fail',\n  errores,\n  n_errores: errores.length,\n  unauthorized,\n  start_ts\n}));\n\nreturn [{\n  json: {\n    run_id,\n    start_ts,\n    valido,\n    unauthorized,\n    errores,\n    payload: body\n  }\n}];"
      },
      "id": "etapa1-validacion",
      "name": "E1 - Validacion de entrada",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-valido",
              "leftValue": "={{ $json.valido }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-valido",
      "name": "IF - Entrada valida?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "check-unauthorized",
              "leftValue": "={{ $json.unauthorized }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-unauthorized",
      "name": "IF - Token invalido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 460]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"ok\": false,\n  \"run_id\": \"{{ $json.run_id }}\",\n  \"error\": \"Token de autenticacion invalido\"\n}",
        "options": { "responseCode": 401 }
      },
      "id": "respond-401",
      "name": "Respond - Token invalido (401)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"ok\": false,\n  \"run_id\": \"{{ $json.run_id }}\",\n  \"errores\": {{ JSON.stringify($json.errores) }}\n}",
        "options": { "responseCode": 400 }
      },
      "id": "respond-400",
      "name": "Respond - Entrada invalida (400)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1120, 560]
    },
    {
      "parameters": {
        "workflowId": "GLCqR9yqvkmE20QY"
      },
      "id": "exec-e2",

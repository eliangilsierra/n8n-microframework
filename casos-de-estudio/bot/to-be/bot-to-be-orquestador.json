      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [900, 200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "workflowId": "EqMaNbc6Rq60G8u9"
      },

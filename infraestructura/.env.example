# =============================================================================
# Variables de entorno para el entorno local de desarrollo
# Copiar este archivo como .env y reemplazar los valores de placeholder
# El archivo .env NUNCA debe ser commiteado al repositorio
# =============================================================================

# --- n8n -----------------------------------------------------------------------
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Bogota

N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-password-seguro

# Mínimo 32 caracteres aleatorios — generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme-32-chars-minimum-random-key-here

# --- PostgreSQL ----------------------------------------------------------------
POSTGRES_DB=sensores_db
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=changeme-password-postgres

# --- Servicios mock (para pruebas locales) -------------------------------------
# Mock de sistema de tickets (caso Bot)
MOCK_TICKETS_API_PORT=3001
MOCK_TICKETS_API_URL=http://host.docker.internal:3001

# Token de autenticacion del Bot (ADR-005 — validado en E1 sin hardcodear)
# Generar con: openssl rand -hex 16
BOT_API_TOKEN=changeme-token-bot-soporte-here

# Mock de notificaciones (caso IoT)
MOCK_NOTIFICACIONES_API_PORT=3002
MOCK_NOTIFICACIONES_API_URL=http://host.docker.internal:3002

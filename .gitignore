# =============================================================================
# Archivos excluidos del repositorio
# =============================================================================

# --- Credenciales y entorno --------------------------------------------------
.env
**/.env
*.env

# --- Python ------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# --- Artefactos generados ----------------------------------------------------
# El HTML se regenera con: python medicion/analizar_runlogs.py
medicion/consolidado/*.html

# Salida de prueba regenerada por microframework/validacion/tests/run-tests.mjs en cada corrida
microframework/validacion/tests/tmp/

# --- Herramientas de desarrollo local ----------------------------------------
.claude/

# --- Archivos de planificación -----------------------------------------------
CLAUDE.md

# --- Base de conocimiento externa --------------------------------------------
# La carpeta final/ es consumida por una base de conocimiento que lee todos los
# documentos en una carpeta plana. No se versiona: se regenera desde las fuentes
# canónicas del repositorio.
final/

# --- n8n datos persistentes --------------------------------------------------
n8n_data/
infraestructura/n8n_data/

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
